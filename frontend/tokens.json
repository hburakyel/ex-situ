{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Ex Situ Design System — W3C Design Token Community Group format. Extracted from V3 codebase.",
  "color": {
    "$type": "color",
    "bg": {
      "base": { "$value": "#ffffff", "$description": "Primary surface — bg-white everywhere" },
      "overlay": { "$value": "hsla(0, 0%, 100%, 0.5)", "$description": "Map loading overlay" },
      "scrim": { "$value": "rgba(0, 0, 0, 0.25)", "$description": "Command palette backdrop" },
      "gallery-overlay": { "$value": "rgba(0, 0, 0, 0.7)", "$description": "Image gallery overlay (CSS)" },
      "panel-backdrop": { "$value": "rgba(229, 229, 229, 0.9)", "$description": "Resizable panel CSS" },
      "surface-subtle": { "$value": "rgba(249, 250, 251, 0.5)", "$description": "Filter bar bg" },
      "error": { "$value": "#fef2f2", "$description": "Map error state" },
      "hover": { "$value": "#f9fafb", "$description": "List row hover" },
      "selected-blue": { "$value": "#eff6ff", "$description": "Active place row" },
      "selected-amber": { "$value": "#fffbeb", "$description": "Active institution row" },
      "chip-orange": { "$value": "#fff7ed", "$description": "Collection filter chips" },
      "link-card-hover": { "$value": "#f5f5f5", "$description": "Wiki link-card hover" },
      "violet": { "$value": "rgba(245, 243, 255, 0.5)", "$description": "Connection finder" },
      "path-country": { "$value": "#dbeafe", "$description": "Path step: country" },
      "path-city": { "$value": "#d1fae5", "$description": "Path step: city" },
      "path-institution": { "$value": "#fef3c7", "$description": "Path step: institution" },
      "path-default": { "$value": "#f3f4f6", "$description": "Path step: default" }
    },
    "text": {
      "primary": { "$value": "#000000", "$description": "Forced on all elements via globals.css" },
      "foreground": { "$value": "hsl(222.2, 84%, 4.9%)", "$description": "CSS --foreground" },
      "muted": { "$value": "hsl(215.4, 16.3%, 46.9%)", "$description": "CSS --muted-foreground" },
      "secondary": { "$value": "#9ca3af", "$description": "Counts, labels, metadata" },
      "tertiary": { "$value": "#6b7280", "$description": "Hints, secondary headings" },
      "panel-muted": { "$value": "hsl(0, 0%, 45%)", "$description": "Panel section labels" },
      "selected-blue": { "$value": "#1e40af", "$description": "Selected place text" },
      "chip-blue": { "$value": "#1d4ed8", "$description": "Country/city chip text" },
      "selected-orange": { "$value": "#9a3412", "$description": "Selected institution text" },
      "chip-orange": { "$value": "#c2410c", "$description": "Institution chip text" },
      "faint": { "$value": "#d1d5db", "$description": "Loading state text" },
      "breadcrumb-separator": { "$value": "rgba(0, 0, 0, 0.4)", "$description": "Mobile breadcrumb slash" },
      "breadcrumb-inactive": { "$value": "rgba(0, 0, 0, 0.6)", "$description": "Mobile breadcrumb ancestor" },
      "error": { "$value": "#ef4444", "$description": "Error messages" },
      "indigo": { "$value": "#4f46e5", "$description": "Wikipedia CTA text" },
      "violet": { "$value": "#7c3aed", "$description": "Connection finder accent" },
      "path-country": { "$value": "#1d4ed8" },
      "path-city": { "$value": "#047857" },
      "path-institution": { "$value": "#b45309" },
      "path-default": { "$value": "#4b5563" }
    },
    "border": {
      "default": { "$value": "hsl(214.3, 31.8%, 91.4%)", "$description": "CSS --border" },
      "subtle": { "$value": "#f3f4f6", "$description": "Section dividers" },
      "light": { "$value": "#e5e7eb", "$description": "Separator lines" },
      "focus-blue": { "$value": "#bfdbfe", "$description": "Selection ring (thin)" },
      "ring-blue": { "$value": "#3b82f6", "$description": "Selection ring (thick)" },
      "ring-amber": { "$value": "#fde68a", "$description": "Institution ring" },
      "map-control": { "$value": "rgba(0, 0, 0, 0.1)", "$description": "Map control border" }
    },
    "accent": {
      "orange": { "$value": "#f97316", "$description": "Institution accent" },
      "blue": { "$value": "#3b82f6", "$description": "Geographic accent" }
    },
    "state": {
      "hover-blue": { "$value": "#dbeafe" },
      "hover-orange": { "$value": "#ffedd5" },
      "alert-bg": { "$value": "#ef4444" },
      "destructive": { "$value": "hsl(0, 84.2%, 60.2%)" }
    },
    "map": {
      "arc-selected": { "$value": "rgba(59, 130, 246, 1)" },
      "arc-selected-target": { "$value": "rgba(147, 51, 234, 1)" },
      "highlight": { "$value": "rgba(59, 130, 246, 1)" },
      "wiki-fill": { "$value": "rgba(99, 102, 241, 0.78)" },
      "wiki-highlight": { "$value": "rgba(139, 92, 246, 1)" },
      "wiki-stroke": { "$value": "#ffffff" },
      "dot-country": { "$value": "#3b82f6" },
      "dot-city": { "$value": "#10b981" },
      "dot-institution": { "$value": "#f59e0b" },
      "dot-default": { "$value": "#6b7280" },
      "tooltip-bg": { "$value": "rgba(0, 0, 0, 0.85)" }
    }
  },
  "typography": {
    "fontFamily": {
      "$type": "fontFamily",
      "mono": {
        "$value": ["ui-monospace", "SFMono-Regular", "Menlo", "Monaco", "Consolas", "Liberation Mono", "Courier New", "monospace"],
        "$description": "Applied to both sans and mono — everything is monospace"
      }
    },
    "fontSize": {
      "$type": "dimension",
      "base": { "$value": "0.875rem", "$description": "14px — forced on all elements" },
      "body-md": { "$value": "0.875rem" },
      "caption": { "$value": "10px" },
      "micro": { "$value": "9px" },
      "label": { "$value": "0.875rem" }
    },
    "fontWeight": {
      "$type": "fontWeight",
      "normal": { "$value": 400, "$description": "Forced via !important" },
      "medium": { "$value": 500, "$description": "Declared but overridden to 400 by globals.css" }
    },
    "lineHeight": {
      "$type": "dimension",
      "body-md": { "$value": "1.25rem" },
      "caption": { "$value": "1" },
      "micro": { "$value": "1" }
    }
  },
  "spacing": {
    "$type": "dimension",
    "0": { "$value": "0px" },
    "px": { "$value": "1px" },
    "0-5": { "$value": "0.125rem" },
    "1": { "$value": "0.25rem" },
    "1-5": { "$value": "0.375rem" },
    "2": { "$value": "0.5rem" },
    "2-5": { "$value": "0.625rem" },
    "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" },
    "5": { "$value": "1.25rem" },
    "6": { "$value": "1.5rem" },
    "8": { "$value": "2rem" },
    "10": { "$value": "2.5rem" }
  },
  "borderRadius": {
    "$type": "dimension",
    "sm": { "$value": "4px" },
    "md": { "$value": "6px" },
    "lg": { "$value": "0.5rem", "$description": "8px — var(--radius)" },
    "tile": { "$value": "10px", "$description": "Image tiles, tooltips" },
    "panel": { "$value": "1rem", "$description": "16px — header + object panel" },
    "palette": { "$value": "1.25rem", "$description": "20px — command palette" },
    "control": { "$value": "6px", "$description": "Map controls" },
    "full": { "$value": "9999px", "$description": "Pills" }
  },
  "shadow": {
    "$type": "shadow",
    "lg": {
      "$value": [
        { "offsetX": "0", "offsetY": "10px", "blur": "15px", "spread": "-3px", "color": "rgba(0, 0, 0, 0.1)" },
        { "offsetX": "0", "offsetY": "4px", "blur": "6px", "spread": "-4px", "color": "rgba(0, 0, 0, 0.1)" }
      ]
    },
    "2xl": {
      "$value": [
        { "offsetX": "0", "offsetY": "25px", "blur": "50px", "spread": "-12px", "color": "rgba(0, 0, 0, 0.25)" }
      ]
    },
    "xl": {
      "$value": [
        { "offsetX": "0", "offsetY": "20px", "blur": "25px", "spread": "-5px", "color": "rgba(0, 0, 0, 0.1)" },
        { "offsetX": "0", "offsetY": "8px", "blur": "10px", "spread": "-6px", "color": "rgba(0, 0, 0, 0.1)" }
      ]
    },
    "control": {
      "$value": [
        { "offsetX": "0", "offsetY": "2px", "blur": "6px", "spread": "0", "color": "rgba(0, 0, 0, 0.1)" }
      ]
    },
    "tooltip": {
      "$value": [
        { "offsetX": "0", "offsetY": "2px", "blur": "10px", "spread": "0", "color": "rgba(0, 0, 0, 0.3)" }
      ]
    },
    "subtle": {
      "$value": [
        { "offsetX": "0", "offsetY": "1px", "blur": "3px", "spread": "0", "color": "rgba(0, 0, 0, 0.05)" }
      ]
    },
    "gallery": {
      "$value": [
        { "offsetX": "0", "offsetY": "10px", "blur": "25px", "spread": "-5px", "color": "rgba(0, 0, 0, 0.1)" },
        { "offsetX": "0", "offsetY": "10px", "blur": "10px", "spread": "-5px", "color": "rgba(0, 0, 0, 0.04)" }
      ]
    },
    "dropdown": {
      "$value": [
        { "offsetX": "0", "offsetY": "4px", "blur": "12px", "spread": "0", "color": "rgba(0, 0, 0, 0.15)" }
      ]
    }
  },
  "motion": {
    "duration": {
      "$type": "duration",
      "fast": { "$value": "150ms" },
      "default": { "$value": "300ms" },
      "image-fade": { "$value": "500ms" },
      "gallery": { "$value": "200ms" },
      "arc": { "$value": "300ms" },
      "loading-gradient": { "$value": "1500ms" },
      "accordion": { "$value": "200ms" },
      "map-fly-fast": { "$value": "800ms" },
      "map-fly-default": { "$value": "1200ms" },
      "map-fly-slow": { "$value": "1400ms" },
      "map-fly-level-shift": { "$value": "2300ms" }
    },
    "easing": {
      "$type": "cubicBezier",
      "fast": { "$value": "ease", "$description": "CSS ease keyword" },
      "default": { "$value": "ease-in-out" },
      "image-fade": { "$value": "ease-out" },
      "gallery": { "$value": "ease-out" },
      "arc": { "$value": "ease-in-out" },
      "accordion": { "$value": "ease-out" }
    }
  },
  "zIndex": {
    "$type": "number",
    "map": { "$value": 1 },
    "map-canvas": { "$value": 2 },
    "map-controls": { "$value": 10 },
    "panel": { "$value": 20 },
    "panel-header": { "$value": 30 },
    "gallery": { "$value": 60 },
    "map-overlay": { "$value": 40 },
    "tooltip": { "$value": 50 },
    "command-palette": { "$value": 80 },
    "alert": { "$value": 70 },
    "map-popup": { "$value": 60 },
    "dropdown": { "$value": 1000 }
  },
  "breakpoint": {
    "$type": "dimension",
    "xs": { "$value": "480px" },
    "sm": { "$value": "640px" },
    "md": { "$value": "768px" },
    "lg": { "$value": "1024px" },
    "xl": { "$value": "1280px" },
    "2xl": { "$value": "1400px" }
  },
  "iconSize": {
    "$type": "dimension",
    "dot": { "$value": "0.375rem" },
    "xs": { "$value": "0.625rem" },
    "sm": { "$value": "0.875rem" },
    "md": { "$value": "1rem" },
    "search-bar": { "$value": "18px" },
    "lg": { "$value": "1.25rem" },
    "xl": { "$value": "2rem" },
    "2xl": { "$value": "3rem" },
    "map-control": { "$value": "15px" },
    "map-control-button": { "$value": "28px" },
    "panel-toggle": { "$value": "18px" }
  }
}
