# Frontend (Next.js) Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── Required ──
# Strapi API
NEXT_PUBLIC_API_BASE_URL=http://localhost:1337/api

# Site URL (used for CORS origin checks)
# NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# ── Basemap tiles (Protomaps + MapLibre) ──
# Option 1: Protomaps CDN (get a free key at https://protomaps.com)
# NEXT_PUBLIC_PROTOMAPS_KEY=your_protomaps_api_key

# Option 2: Self-hosted PMTiles file (URL to your .pmtiles file)
# NEXT_PUBLIC_PROTOMAPS_PMTILES_URL=https://your-cdn.com/basemap.pmtiles

# If neither is set, the app uses the public Protomaps basemap (no key needed).

# Strapi webhook auth (must match your Strapi webhook config)
# STRAPI_API_TOKEN=your_strapi_api_token
# STRAPI_WEBHOOK_ORIGIN=http://localhost:1337
